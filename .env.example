# Frontend (Vite) env vars — copy to .env and fill in real values

# In development, the Vite proxy forwards /api/* to localhost:8000
VITE_API_BASE_URL=/api
VITE_BACKEND_URL=http://localhost:8000

# In production, set this to your Render backend URL:
# VITE_BACKEND_URL=https://dl-virtual-teacher-backend.onrender.com

# Clerk authentication
VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here

# xAI / Grok (used by the backend — set in backend/.env or Render env vars)
XAI_API_KEY=your_xai_api_key_here
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4.3

# Google Gemini (recommended free tier — get key at https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq (optional fallback — get key at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
