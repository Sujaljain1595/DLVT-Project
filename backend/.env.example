# Backend environment variables — copy to backend/.env and fill in real values
# These are set as secret env vars in the Render dashboard (never commit real keys!)

# xAI / Grok
XAI_API_KEY=your_xai_api_key_here
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4.3

# Google Gemini (recommended — free tier, get key at https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq (optional fallback — get key at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
